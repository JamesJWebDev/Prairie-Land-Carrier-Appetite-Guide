{
  "name": "prairie-land-carriers-appetite-guide",
  "version": "1.0.0",
  "description": "Prairie Land Carrier's Appetite Guide – internal Electron desktop tool to suggest carrier markets based on underwriting-style inputs.",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "build-icon": "node scripts/build-icon.js",
    "pack": "electron-vite build && node scripts/pack.js",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage"
  },
  "keywords": [],
  "author": "Prairie Land Insurance Agency Inc.",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.prairieland.appetiteguide",
    "productName": "Prairie Land Carrier's Appetite Guide",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "electron": "^40.2.1",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.0",
    "png-to-ico": "^2.1.1",
    "sharp": "^0.33.5",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
